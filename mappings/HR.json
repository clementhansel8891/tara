{
  "module": "HR",
  "name": "Human Resources",
  "purpose": "Enterprise HR operating system with workflow-native approvals and lifecycle management.",
  "navigation": [
    {
      "section": "Dashboard",
      "label": "PulseDesk",
      "path": "/core/hr",
      "roles": ["HR_ADMIN", "COMPANY_ADMIN", "DEPT_HEAD", "OWNER", "SUPERADMIN"],
      "purpose": "Workforce metrics, alerts, and real-time HR KPIs."
    },
    {
      "section": "People",
      "label": "People Directory",
      "path": "/core/hr/roster",
      "subpages": ["/core/hr/people/:userId"],
      "purpose": "Master employee roster and 360-degree digital profiles."
    },
    {
      "section": "Hiring",
      "label": "Talent",
      "path": "/core/hr/talent",
      "ai_features": [
        "AI Job Description Generation",
        "Market Alignment Benchmarking",
        "Talent Lead Ingestion & Matching"
      ],
      "workflow": "ATS Pipeline & Lead-to-Candidate Conversion"
    },
    {
      "section": "Organization",
      "label": "Org Structure",
      "path": "/core/hr/org-map",
      "planning": ["Headcount Scenarios", "What-If Analysis", "Succession Modeling"],
      "purpose": "Visual organizational hierarchy and departmental mappings."
    },
    {
      "section": "Performance",
      "label": "Performance",
      "path": "/core/hr/growth",
      "items": [
        { "label": "Career Pathing", "path": "/core/hr/career", "purpose": "AI role suggestions and readiness forecasting." },
        { "label": "Mentorship", "path": "/core/hr/mentorship", "purpose": "Skill-based mentor matching." },
        { "label": "Learning ROI", "path": "/core/hr/learning", "purpose": "Personalized training and impact analytics." },
        { "label": "Talent Marketplace", "path": "/core/hr/marketplace", "purpose": "Internal skill-based talent search." }
      ]
    },
    {
      "section": "Payroll",
      "label": "Payroll",
      "path": "/core/hr/paycycle",
      "integration": "Finance",
      "multi_currency": ["Exchange Rates", "Consolidated Reporting", "Total Rewards"],
      "forecasting": ["Labor Cost Projection", "Inflation Simulation", "Budget Variance"]
    },
    {
      "section": "Compliance",
      "label": "Compliance OS",
      "path": "/core/hr/lexboard",
      "items": [
        { "label": "Smart Vault", "path": "/core/hr/vault", "purpose": "OCR-powered secure document management." },
        { "label": "Compliance Engine", "path": "/core/hr/compliance/engine", "purpose": "Per-country module calculations (ID, SG, AE)." },
        { "label": "Export Center", "path": "/core/hr/compliance/export", "purpose": "CSV, Excel, XML, PDF generated downloads." },
        { "label": "Government Portals", "path": "/core/hr/compliance/portals", "purpose": "DJP Online, BPJS, MyCPF, MOHRE portals." },
        { "label": "AI Suggestions", "path": "/core/hr/compliance/ai-suggestions", "purpose": "Automated compliance module recommendations." }
      ]
    },
    {
      "section": "Intelligence",
      "label": "Insights",
      "path": "/core/hr/insights",
      "predictions": ["Turnover Modeling", "Flight Risk Detection", "Performance Forecasting", "Bench Strength Analysis"]
    },
    {
      "section": "Approvals",
      "label": "Approval Center",
      "path": "/core/hr/flowgate",
      "purpose": "Centralized gate for all HR lifecycle approvals."
    },
    {
      "section": "Employee Portal",
      "label": "My Pulse",
      "path": "/core/hr/portal",
      "roles": ["STAFF"],
      "purpose": "Employee self-service (payslips, leave, profile)."
    },
    {
      "section": "Time & Attendance",
      "label": "Time & Tracker",
      "path": "/core/hr/time",
      "features": ["Leave Management", "Attendance Tracking", "Holiday Calendar", "Shift Scheduling"],
      "integration": ["Payroll", "Employee Portal"],
      "purpose": "Centralized time, leave, and shift tracking module."
    }
  ],
  "lifecycle": [
    "Candidate", "Offer", "Hired", "Probation", "Active", 
    "Transferred", "Promoted", "On Leave", "Suspended", "Terminated"
  ],
  "integrations": ["IT Provisioning", "Finance Sync", "Security RBAC", "Global Audit Log", "Compliance Engine", "CommandBus"],
  "commands": {
    "general": ["HireEmployeeCommand", "PromoteEmployeeCommand", "TransferEmployeeCommand", "TerminateEmployeeCommand", "SuspendEmployeeCommand"],
    "recruitment": ["CreateJobOpeningCommand", "ConvertLeadToCandidateCommand", "ScheduleInterviewCommand"],
    "payroll": ["ExecutePayrollCommand", "AdjustCompensationCommand", "GeneratePayslipCommand"],
    "compliance": ["GenerateComplianceReportCommand", "ExportGovernmentReportCommand", "EnableComplianceModuleCommand"]
  },
  "events": {
    "employee": ["employee.created", "employee.promoted", "employee.transferred", "employee.suspended", "employee.terminated"],
    "recruitment": ["candidate.converted", "interview.scheduled"],
    "payroll": ["payroll.executed", "payslip.generated"],
    "compliance": ["compliance.report.generated", "compliance.module.enabled"]
  },
  "automation_hooks": [
    {
      "trigger": "employee.created",
      "actions": ["IT provisioning", "payroll profile creation", "compliance registration"]
    },
    {
      "trigger": "payroll.executed",
      "actions": ["compliance calculation", "government report generation"]
    }
  ]
}
