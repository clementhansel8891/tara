{
  "module": "Zenvix HRIS",
  "workflows": [
    {
      "name": "PulseDesk",
      "purpose": "Operational command inbox",
      "actions": [
        { "label": "Search Bar", "outcome": "Filters workstream items by title or creator" },
        { "label": "Status Filter", "outcome": "Filters items by status (PENDING, APPROVED, REJECTED)" },
        { "label": "Create Request", "outcome": "Triggers ad-hoc approval routes (Default: LEAVE)" },
        { "label": "Item Card", "outcome": "Navigates to FlowGate detail view" }
      ]
    },
    {
      "name": "RosterGrid",
      "purpose": "Staff lifecycle management",
      "actions": [
        { "label": "New Employee", "outcome": "Opens onboarding modal for registration" },
        { "label": "Filter Bar", "outcome": "Refines list by Dept, Status, or Role" },
        { "label": "Row Click", "outcome": "Opens PeopleCore (Employee 360)" },
        { "label": "Edit Profile", "outcome": "Update identity and structural data" },
        { "label": "Request Termination", "outcome": "Triggers FlowGate termination workflow" },
        { "label": "Send to FlowGate", "outcome": "Manual escalation to approval engine" }
      ]
    },
    {
      "name": "PeopleCore",
      "purpose": "Employee 360 overview",
      "tabs": [
        { "name": "Identity", "function": "Employment detail management" },
        { "name": "Attendance", "function": "Clock-in and shift tracking" },
        { "name": "Payroll", "function": "Payment history and payslip access" },
        { "name": "Performance", "function": "Review history and active growth cycles" },
        { "name": "Contracts", "function": "Legal status and agreement tracking" }
      ],
      "actions": [
        { "label": "Start Workflow", "outcome": "Creates approval request tied to the employee record" }
      ]
    },
    {
      "name": "TalentFlow",
      "purpose": "Recruitment & ATS",
      "actions": [
        { "label": "Create Requisition", "outcome": "Starts hiring approval request" },
        { "label": "Schedule Interview", "outcome": "Logs activity and notifies stakeholders" },
        { "label": "Hire Decision", "outcome": "Finalizes hiring and pushes data to RosterGrid" }
      ]
    },
    {
      "name": "FlowGate",
      "purpose": "Global Approval Logic",
      "actions": [
        { "label": "APPROVE", "outcome": "Finalizes change and updates database state" },
        { "label": "REJECT", "outcome": "Cancels request and notifies creator" },
        { "label": "MODIFY", "outcome": "Requests correction from original requester" }
      ]
    }
  ]
}
