# --- Backend Production Environment Variables ---

# Server Port (Render sets this automatically, but local prod uses 3001)
PORT=3001

# Application Mode
NODE_ENV=production
PERSISTENCE_MODE=mock
BACKEND_URL=http://localhost:3001

# Security
# Set this to a long random string (e.g., openssl rand -base64 32)
JWT_SECRET=
RETAIL_AUTH_JWT_SECRET=

# CORS
# The URL of your deployed frontend (e.g., https://zenvix-frontend.onrender.com)
# For multiple origins, separate by comma: https://site1.com,https://site2.com
ALLOWED_ORIGINS=

# --- Marketing & Growth Engine Integrations ---
# Meta (Facebook/Instagram/WhatsApp)
META_APP_ID=
META_APP_SECRET=
META_BUSINESS_API_TOKEN=
META_PHONE_ID=

# Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
