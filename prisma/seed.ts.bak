import { PrismaClient } from "@prisma/client";

const prisma = new PrismaClient();

async function main() {
  console.log("Starting Master Database Seeder...");

  const globalTenantId = "global";
  const demoTenantId = "comp-demo-a";

  // --- 1. SEED COMPANIES ---
  const companies = [
    {
      id: globalTenantId,
      name: "Zenvix Global platform",
      code: "GLOBAL",
      industry: "saas",
    },
    {
      id: demoTenantId,
      name: "Zenvix Demo Corp",
      code: "ZDX",
      industry: "retail",
    },
  ];

  for (const c of companies) {
    await prisma.company.upsert({
      where: { id: c.id },
      update: { name: c.name, code: c.code, industry: c.industry },
      create: c,
    });
  }
  console.log("Companies seeded.");

  // --- 2. ADMIN MODULE STATUSES ---
  const modules = [
    "finance",
    "hr",
    "it",
    "admin",
    "retail",
    "sales",
    "procurement",
  ];
  for (const moduleKey of modules) {
    try {
      await (prisma as any).adminModuleStatus.upsert({
        where: { tenantId_moduleKey: { tenantId: demoTenantId, moduleKey } },
        update: { enabled: true },
        create: {
          tenantId: demoTenantId,
          moduleKey,
          enabled: true,
          updatedBy: "system",
        },
      });
    } catch (e) {
      // Ignore if model doesn't exist in this schema version (it appeared in seed.ts earlier)
      console.log(
        `Skipping module status for ${moduleKey} (model might be missing in schema)`,
      );
    }
  }

  // --- 3. SEED USERS (zenvix123) ---
  const commonPasswordHash =
    "$2a$10$yycoCL97bRvbcXdNjKXqP.J3fmu2HBt5yq4eKO4Vh0pwbYoD4ZWD2";
  const users = [
    {
      id: "usr-superadmin-001",
      email: "superadmin@zenvix.com",
      firstName: "Super",
      lastName: "Admin",
      passwordHash: commonPasswordHash,
    },
    {
      id: "usr-demo-001",
      email: "demo@zenvix.com",
      firstName: "Demo",
      lastName: "Owner",
      passwordHash: commonPasswordHash,
    },
  ];

  for (const u of users) {
    await prisma.user.upsert({
      where: { email: u.email },
      update: { firstName: u.firstName, lastName: u.lastName },
      create: u,
    });
  }
  console.log("Users seeded.");

  // --- 4. SEED ROLES ---
  const userCompanies = [
    {
      userId: "usr-superadmin-001",
      tenantId: globalTenantId,
      role: "SUPERADMIN",
      isDefault: true,
    },
    {
      userId: "usr-demo-001",
      tenantId: demoTenantId,
      role: "OWNER",
      isDefault: true,
    },
  ];

  for (const uc of userCompanies) {
    await prisma.userCompany.upsert({
      where: { userId_tenantId: { userId: uc.userId, tenantId: uc.tenantId } },
      update: { role: uc.role },
      create: uc,
    });
  }
  console.log("User roles seeded.");

  // --- 5. LOCATIONS & DEPARTMENTS ---
  const location = await prisma.location.upsert({
    where: { tenantId_code: { tenantId: demoTenantId, code: "GI-001" } },
    update: {},
    create: {
      tenantId: demoTenantId,
      name: "Grand Indonesia Flagship",
      code: "GI-001",
      type: "branch",
      currency: "IDR",
    },
  });

  const depts = [
    { code: "HR", name: "Human Resources" },
    { code: "FIN", name: "Finance" },
    { code: "IT", name: "Information Technology" },
  ];

  for (const d of depts) {
    await prisma.department.upsert({
      where: { tenantId_code: { tenantId: demoTenantId, code: d.code } },
      update: { name: d.name },
      create: {
        tenantId: demoTenantId,
        code: d.code,
        name: d.name,
        status: "active",
      },
    });
  }
  console.log("Departments seeded.");

  const categories = ["Electronics", "Clothing", "Furniture"];
  const catMap: Record<string, string> = {};
  for (const cat of categories) {
    const c = await prisma.productCategory.upsert({
      where: { tenantId_name: { tenantId: demoTenantId, name: cat } },
      update: {},
      create: { tenantId: demoTenantId, name: cat },
    });
    catMap[cat] = c.id;
  }

  // --- 6. PRODUCTS & STOCK ---
  const products = [
    {
      sku: "ELEC-MBP-001",
      name: "MacBook Pro 14 M3",
      cat: "Electronics",
      price: 32999000,
    },
    {
      sku: "ELEC-IPN-015",
      name: "iPhone 15 Pro",
      cat: "Electronics",
      price: 18999000,
    },
  ];

  for (const p of products) {
    const product = await prisma.product.upsert({
      where: { tenantId_sku: { tenantId: demoTenantId, sku: p.sku } },
      update: { name: p.name, categoryId: catMap[p.cat], basePrice: p.price },
      create: {
        tenantId: demoTenantId,
        sku: p.sku,
        name: p.name,
        categoryId: catMap[p.cat],
        basePrice: p.price,
        barcode: `EAN-${Math.random().toString().slice(2, 10)}`,
        unit: "PCS",
        status: "active",
      },
    });

    // Handle stock level manually due to potential NULL department issues in upsert
    const stock = await prisma.stockLevel.findFirst({
      where: {
        productId: product.id,
        locationId: location.id,
        departmentId: null,
      },
    });

    if (stock) {
      await prisma.stockLevel.update({
        where: { id: stock.id },
        data: { onHand: 50, available: 50 },
      });
    } else {
      await prisma.stockLevel.create({
        data: {
          tenantId: demoTenantId,
          locationId: location.id,
          productId: product.id,
          onHand: 50,
          available: 50,
        },
      });
    }
  }

  // --- 7. PROCUREMENT SEEDING ---
  const procurementSuppliers = [
    {
      name: "Global Tech Solutions",
      taxId: "TX-GTS-001",
      categories: ["Electronics", "IT Services"],
      branches: [
        {
          code: "JKT-01",
          name: "Jakarta HQ",
          location: "Central Jakarta",
          products: [
            {
              sku: "SVR-DELL-R740",
              name: "Dell PowerEdge R740",
              cat: "Electronics",
              price: 45000000,
            },
          ],
        },
      ],
    },
    {
      name: "Indo Fabric Master",
      taxId: "TX-IFM-002",
      categories: ["Clothing", "Raw Materials"],
      branches: [
        {
          code: "BDG-01",
          name: "Bandung Factory",
          location: "South Bandung",
          products: [
            {
              sku: "FAB-COTTON-100",
              name: "Premium Cotton 100%",
              cat: "Clothing",
              price: 150000,
            },
          ],
        },
      ],
    },
  ];

  for (const s of procurementSuppliers) {
    const master = await prisma.supplierMaster.upsert({
      where: {
        id: `sup-${s.name.toLowerCase().replace(/\s+/g, "-")}`,
      },
      update: { name: s.name, categories: s.categories },
      create: {
        id: `sup-${s.name.toLowerCase().replace(/\s+/g, "-")}`,
        tenantId: demoTenantId,
        name: s.name,
        taxId: s.taxId,
        categories: s.categories,
        complianceStatus: "VERIFIED",
        globalRating: 85,
        riskTier: "LOW",
      },
    });

    for (const b of s.branches) {
      const branch = await prisma.supplierBranch.upsert({
        where: { id: `br-${master.id}-${b.code.toLowerCase()}` },
        update: { branchName: b.name, location: b.location },
        create: {
          id: `br-${master.id}-${b.code.toLowerCase()}`,
          tenantId: demoTenantId,
          supplierId: master.id,
          branchCode: b.code,
          branchName: b.name,
          location: b.location,
          leadTimeDays: 5,
          localRating: 90,
          riskTier: "LOW",
          active: true,
        },
      });

      for (const p of b.products) {
        await prisma.supplierProduct.upsert({
          where: { id: `prod-${branch.id}-${p.sku.toLowerCase()}` },
          update: { unitPrice: p.price },
          create: {
            id: `prod-${branch.id}-${p.sku.toLowerCase()}`,
            tenantId: demoTenantId,
            supplierId: master.id,
            branchId: branch.id,
            sku: p.sku,
            name: p.name,
            category: p.cat,
            unitPrice: p.price,
            currency: "IDR",
            qualityScore: 95,
            active: true,
          },
        });
      }
    }
  }

  console.log("Procurement data seeded.");
  console.log("Master Seed Completed Successfully.");
}

main()
  .catch((e) => {
    console.error("Fatal Seed Error:", e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
