  position       Position @relation(fields: [positionId], references: [id])
  skill          Skill    @relation(fields: [skillId], references: [id])
  company        Company  @relation(fields: [tenantId], references: [id])

  @@unique([positionId, skillId])
  @@index([tenantId])
  @@map("hr_position_skills")
}

model ProgramSkill {
  id                String          @id @default(uuid())
  tenantId          String          @map("tenant_id")
  programId         String          @map("program_id")
  skillId           String          @map("skill_id")
  proficiencyGain   Int             @default(1) @map("proficiency_gain")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  trainingProgram   TrainingProgram @relation(fields: [programId], references: [id])
  skill             Skill           @relation(fields: [skillId], references: [id])
  company           Company         @relation(fields: [tenantId], references: [id])

  @@unique([programId, skillId])
  @@index([tenantId])
  @@map("hr_program_skills")
}

model Skill {
  id                 String               @id @default(uuid())
  tenantId           String               @map("tenant_id")
  name               String
  category           String
  description        String?
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  employeeSkill      EmployeeSkill[]
  positionSkill      PositionSkill[]
  programSkill       ProgramSkill[]
  company            Company              @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("hr_skills")
}

model SuccessionCandidate {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  planId              String              @map("plan_id")
  employeeId          String              @map("candidate_id")
  readiness           String              @default("EMERGENCY")
  readinessScore      Int                 @default(0) @map("readiness_score")
  riskOfLoss          String              @default("LOW") @map("risk_of_loss")
  impactOfLoss        String              @default("MEDIUM") @map("impact_of_loss")
  skillGaps           String[]            @map("skill_gaps")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  employee            Employee            @relation(fields: [employeeId], references: [id])
  successionPlan      SuccessionPlan      @relation(fields: [planId], references: [id])
  company             Company             @relation(fields: [tenantId], references: [id])

  @@index([employeeId])
  @@index([tenantId])
  @@map("hr_succession_candidates")
}

model SuccessionPlan {
  id                  String                @id @default(uuid())
  tenantId            String                @map("tenant_id")
  positionId          String                @unique @map("position_id")
  isCritical          Boolean               @default(true) @map("is_critical")
  strategy            String?
  notes               String?
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  candidates          SuccessionCandidate[]
  position            Position              @relation(fields: [positionId], references: [id])
  company             Company               @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("hr_succession_plans")
}

model TalentLead {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  source               String   @default("LINKEDIN")
  externalProfileUrl   String?  @map("external_profile_url")
  name                 String
  email                String?
  phone                String?
  headline             String?
  skills               Json?
  leadScore            Int      @default(0) @map("lead_score")
  status               String   @default("LEAD")
  metadata             Json?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  company              Company  @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([tenantId])
  @@map("hr_talent_leads")
}

model Interview {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  candidateId    String    @map("candidate_id")
  interviewerId String    @map("interviewer_id")
  title          String
  scheduledAt    DateTime  @map("scheduled_at")
  duration       Int       @default(30)
  location       String?
  status         String    @default("SCHEDULED")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  candidate      Candidate @relation(fields: [candidateId], references: [id])
  interviewer    Employee  @relation(fields: [interviewerId], references: [id])
  company        Company   @relation(fields: [tenantId], references: [id])

  @@index([candidateId])
  @@index([tenantId])
  @@map("interviews")
}

model HRCase {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  employeeId     String    @map("employee_id")
  category       String?
  type           String?
  title          String?
  priority       String    @default("MEDIUM")
  status         String    @default("OPEN")
  subject        String?
  description    String?
  ownerId        String?   @map("owner_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  departmentId   String?   @map("department_id")
  employee       Employee  @relation(fields: [employeeId], references: [id])
  department     Department? @relation(fields: [departmentId], references: [id])
  company        Company   @relation("CompanyToHRCase", fields: [tenantId], references: [id])

  @@index([employeeId])
  @@index([tenantId])
  @@map("hr_cases")
}

model JobRole {
  id               String     @id
  tenantId         String     @map("tenant_id")
  name             String
  code             String
  description      String?
  baseSalaryMin    Decimal?   @map("base_salary_min") @db.Decimal(15, 2)
  baseSalaryMax    Decimal?   @map("base_salary_max") @db.Decimal(15, 2)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  employees        Employee[]
  company          Company    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("job_roles")
}

model WorkflowAuditEntry {
  id              String          @id @default(uuid())
  tenantId        String          @map("tenant_id")
  workflowId      String          @map("workflow_id")
  action          String
  actorId         String          @map("actor_id")
  actorRole       String?         @map("actor_role")
  notes           String?
  metadata        Json?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  cycle           Int             @default(1)
  after           Json?
  workflow        WorkflowRequest @relation(fields: [workflowId], references: [id])
  company         Company         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([workflowId])
  @@map("workflow_audit_entries")
}

model PayrollProfile {
  id            String   @id
  tenantId      String   @map("tenant_id")
  employeeId    String   @unique @map("employee_id")
  bankName      String?  @map("bank_name")
  bankAccountNo String?  @map("bank_account_no")
  taxId         String?  @map("tax_id")
  socialSecurityNo String? @map("social_security_no")
  paymentMethod String   @default("bank_transfer") @map("payment_method")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  employee      Employee @relation(fields: [employeeId], references: [id])
  company       Company  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("payroll_profiles")
}

model Position {
  id                   String               @id @default(uuid())
  tenantId             String               @map("tenant_id")
  locationId           String               @map("location_id")
  departmentId         String               @map("department_id")
  title                String
  grade                String
  status               String               @default("open")
  budgetedSalary       Decimal?             @map("budgeted_salary") @db.Decimal(15, 2)
  reportsToPositionId  String?              @map("reports_to_position_id")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  deletedAt            DateTime?            @map("deleted_at")
  jobPostMetadata      Json?                @map("job_post_metadata")
  fromCareerPath       CareerPath[]         @relation("hr_career_paths_from_position_idTopositions")
  toCareerPath         CareerPath[]         @relation("hr_career_paths_to_position_idTopositions")
  skills               PositionSkill[]
  successionPlan       SuccessionPlan?
  department           Department           @relation(fields: [departmentId], references: [id])
  location             Location             @relation(fields: [locationId], references: [id])
  company              Company              @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@map("positions")
}

model WorkflowRequest {
  id               String               @id @default(uuid())
  tenantId         String               @map("tenant_id")
  entityType       String               @map("entity_type")
  entityId         String               @map("entity_id")
  requestedBy      String?              @map("requested_by")
  makerDept        String               @map("maker_dept")
  destinationDept  String               @map("destination_dept")
  status           String               @default("PENDING")
  lastAction       String?              @map("last_action")
  notes            String?
  metadata         Json?
  cycle            Int                  @default(1)
  steps            Json?
  route            Json?
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  workflowAuditEntry WorkflowAuditEntry[]
  company          Company              @relation(fields: [tenantId], references: [id])

  @@index([entityType, entityId])
  @@index([status])
  @@index([tenantId])
  @@map("workflow_requests")
}

enum ItemType {
  ITEM
  SERVICE
  RAW_MATERIAL
}

enum ChatRoomType {
  DIRECT
  GROUP
  DEPARTMENT
  LOCATION
  COMPANY
  ROLE
}

enum ChatMessageType {
  TEXT
  FILE
  QUOTE
  image
  system
  text
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model UserNotificationPreference {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  module    String
  eventType String   @map("event_type")
  channel   NotificationChannel
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company   Company  @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, module, eventType])
  @@unique([tenantId, userId, module, eventType, channel])
  @@map("user_notification_preferences")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}
