generator client {
  provider = "prisma-client-js"
}

generator backend_client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                      String                      @id @default(uuid())
  name                    String
  code                    String                      @unique
  status                  String                      @default("active")
  createdAt               DateTime                    @default(now()) @map("created_at")
  updatedAt               DateTime                    @updatedAt @map("updated_at")
  deletedAt               DateTime?                   @map("deleted_at")
  country                 String                      @default("US")
  currency                String                      @default("USD")
  industry                String                      @default("retail")
  attendanceRecords       AttendanceRecord[]
  auditLogs               AuditLog[]
  bulletinCategories      BulletinCategory[]
  bulletinComments        BulletinComment[]
  bulletinPosts           BulletinPost[]
  bulletinReactions       BulletinReaction[]
  candidates              Candidate[]
  capexRequests           CapexRequest[]
  chatMembers             ChatMember[]
  chatMessages            ChatMessage[]
  chatRooms               ChatRoom[]
  compensations           Compensation[]
  contracts               Contract[]
  departments             Department[]
  ecommerceConnectors     EcommerceConnector[]
  emergencyOverrides      EmergencyOverride[]
  employees               Employee[]
  fixedAssets             FixedAsset[]
  benefitPlans            BenefitPlan[]
  budgetScenarios         BudgetScenario[]
  careerPaths             CareerPath[]
  complianceDocuments     ComplianceDocument[]
  complianceModules       ComplianceModule[]
  complianceReports       ComplianceReport[]
  exchangeRates           ExchangeRate[]
  holidays                Holiday[]
  performanceGoals        PerformanceGoal[]
  skills                  Skill[]
  employeeBenefits        EmployeeBenefit[]
  employeeSkills          EmployeeSkill[]
  positionSkills          PositionSkill[]
  programSkills           ProgramSkill[]
  mentorshipPairs         MentorshipPair[]
  headcountPlans          HeadcountPlan[]
  successionCandidates     SuccessionCandidate[]
  successionPlans         SuccessionPlan[]
  talentLeads             TalentLead[]
  interviews              Interview[]
  inventoryAdjustments    InventoryAdjustment[]
  inventoryAlerts         InventoryAlert[]
  inventoryAuditCycles    InventoryAuditCycle[]
  inventoryIntegrations   InventoryIntegrationEvent[]
  inventoryPools          InventoryPool[]
  itDevices               ITDevice[]
  itProvisioningRequests  ITProvisioningRequest[]
  itSettings              ITSetting[]
  itSystemHealth          ITSystemHealth[]
  products                Product[]
  jobRequisitions         JobRequisition[]
  jobRoles                JobRole[]
  journalEntries          JournalEntry[]
  journalLines            JournalLine[]
  labelConfigs            LabelConfig[]
  leaveRequests           LeaveRequest[]
  locations               Location[]
  mailAccounts            MailAccount[]
  mailLabels              MailLabel[]
  mailMessages            MailMessage[]
  mailThreads             MailThread[]
  marketingAccounts       MarketingConnectedAccount[]
  marketingAlerts         MarketingAlert[]
  marketingAttributions   MarketingAttribution[]
  marketingAuditEvents    MarketingAuditEvent[]
  marketingCampaigns      MarketingCampaign[]
  marketingExecutions     MarketingExecutionRun[]
  marketingLeads          MarketingLead[]
  marketingWorkflows      MarketingNurtureWorkflow[]
  moduleLicenseLogs       ModuleLicenseLog[]
  moduleLicenses          ModuleLicense[]
  moneySources            MoneySource[]
  notifications           Notification[]
  users                   User[]
  userNotificationPreferences UserNotificationPreference[]
  payables                Payable[]
  paymentAuditEvents      PaymentAuditEvent[]
  paymentChargebacks      PaymentChargeback[]
  paymentDevicePools      PaymentDevicePool[]
  paymentDisputes         PaymentDispute[]
  paymentEvidencePacks    PaymentEvidencePack[]
  paymentPosDevices       PaymentPosDevice[]
  paymentProviders        PaymentProvider[]
  paymentRefunds          PaymentRefund[]
  paymentRetryAttempts    PaymentRetryAttempt[]
  paymentRoutingPolicies  PaymentRoutingPolicy[]
  paymentSettlements      PaymentSettlement[]
  paymentTransactions     PaymentTransaction[]
  payrollLines            PayrollLine[]
  payrollProfiles         PayrollProfile[]
  payrollRuns             PayrollRun[]
  performanceCycles       PerformanceCycle[]
  performanceReviews      PerformanceReview[] @relation("CompanyToPerformanceReview")
  hrCases                 HRCase[]            @relation("CompanyToHRCase")
  posDevices              POSDevice[]
  positions               Position[]
  procurementAuditEvents  ProcurementAuditEvent[]
  procurementCategories   ProcurementCategory[]
  procurementContracts    ProcurementContract[]
  procurementDraftPOs     ProcurementDraftPO[]
  procurementFinalPOs     ProcurementFinalPO[]
  procurementRatingLogs   ProcurementRatingLog[]
  procurementReceipts     ProcurementReceipt[]
  procurementRequisitions ProcurementRequisition[]
  procurementRiskSignals  ProcurementRiskSignal[]
  productCategories       ProductCategory[]
  productProjections      ProductProjection[]
  receivables             Receivable[]
  retailCarts             RetailCart[]
  retailChannels          RetailChannel[]
  retailCustomerSessions  RetailCustomerSession[]
  retailCustomers         RetailCustomer[]
  retailGatewayNodes      RetailGatewayNode[]
  retailLoadBalancers     RetailLoadBalancer[]
  retailOrderItems        RetailOrderItem[]
  retailOrders            RetailOrder[]
  retailPromotions        RetailPromotion[]
  retailShifts            RetailShift[]
  retailWishlists         RetailWishlist[]
  salesAlerts             SalesAlert[]
  salesAuditEvents        SalesAuditEvent[]
  salesLeads              SalesLead[]
  salesOpportunities      SalesOpportunity[]
  salesOrders             SalesOrder[]
  salesQuotes             SalesQuote[]
  salesTasks              SalesTask[]
  salesTimelineEvents     SalesTimelineEvent[]
  scheduleAssignments     ScheduleAssignment[]
  settlementRecords       SettlementRecord[]
  shiftSwapRequests       ShiftSwapRequest[]
  shifts                  Shift[]
  stockLevels             StockLevel[]
  stockMovements          StockMovement[]
  stores                  Store[]
  supplierBranches        SupplierBranch[]
  supplierMasters         SupplierMaster[]
  supplierPortalMessages  SupplierPortalMessage[]
  supplierProducts        SupplierProduct[]
  systemLogs              SystemLog[]
  trainingAssignments     TrainingAssignment[]
  trainingPrograms        TrainingProgram[]
  treasuryTransfers       TreasuryTransfer[]
  userCompanies           UserCompany[]
  workflowRequests        WorkflowRequest[]
  workflowAuditEntries    WorkflowAuditEntry[]

  @@index([status])
  @@map("companies")
}

model User {
  id                      String                      @id @default(uuid())
  tenantId                String                      @map("tenant_id")
  email                   String                      @unique
  passwordHash            String                      @map("password_hash")
  firstName               String                      @map("first_name")
  lastName                String                      @map("last_name")
  phone                   String?
  status                  String                      @default("active")
  avatarUrl               String?                     @map("avatar_url")
  createdAt               DateTime                    @default(now()) @map("created_at")
  updatedAt               DateTime                    @updatedAt @map("updated_at")
  chatMembers             ChatMember[]
  userCompanies           UserCompany[]
  userNotificationPreferences UserNotificationPreference[]
  company                 Company                     @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
}

model UserCompany {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  role      String   @default("ADMIN")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("user_companies")
}

model Location {
  id                   String                @id @default(uuid())
  tenantId             String                @map("tenant_id")
  name                 String
  code                 String
  address              String?
  type                 String
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")
  country              String?
  currency             String?
  attendanceRecords    AttendanceRecord[]
  chatRooms            ChatRoom[]
  employees            Employee[]
  inventoryAdjustments InventoryAdjustment[]
  itDevices            ITDevice[]
  labelConfigs         LabelConfig[]
  company              Company               @relation(fields: [tenantId], references: [id])
  positions            Position[]
  productProjections   ProductProjection[]
  scheduleAssignments  ScheduleAssignment[]
  stockLevels          StockLevel[]
  fromMovements        StockMovement[]       @relation("FromLocation")
  toMovements          StockMovement[]       @relation("ToLocation")
  stores               Store[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("locations")
}

model Department {
  id                      String                   @id @default(uuid())
  tenantId                String                   @map("tenant_id")
  name                    String
  code                    String
  headId                  String?                  @map("head_id")
  description             String?
  status                  String                   @default("active")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  deletedAt               DateTime?                @map("deleted_at")
  chatRooms               ChatRoom[]
  company                 Company                  @relation(fields: [tenantId], references: [id])
  employees               Employee[]
  hrCases                 HRCase[]
  hr_headcount_plans      HeadcountPlan[]
  inventoryAdjustments    InventoryAdjustment[]
  products                Product[]
  jobRequisitions         JobRequisition[]
  leaveRequests           LeaveRequest[]
  paymentTransactions     PaymentTransaction[]
  positions               Position[]
  procurementRequisitions ProcurementRequisition[]
  stockLevels             StockLevel[]
  fromMovements           StockMovement[]          @relation("FromDepartment")
  toMovements             StockMovement[]          @relation("ToDepartment")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@map("departments")
}

model Employee {
  id                                                           String                     @id @default(uuid())
  tenantId                                                     String                     @map("tenant_id")
  locationId                                                   String                     @map("location_id")
  departmentId                                                 String                     @map("department_id")
  firstName                                                    String                     @map("first_name")
  lastName                                                     String                     @map("last_name")
  email                                                        String
  phone                                                        String?
  userId                                                       String?                    @map("user_id")
  managerId                                                    String?                    @map("manager_id")
  position                                                     String
  employeeCode                                                 String                     @map("employee_code")
  employmentType                                               String                     @default("full_time") @map("employment_type")
  baseSalary                                                   Decimal?                   @map("base_salary") @db.Decimal(15, 2)
  hourlyRate                                                   Decimal?                   @map("hourly_rate") @db.Decimal(15, 2)
  hireDate                                                     DateTime                   @map("hire_date")
  terminationDate                                              DateTime?                  @map("termination_date")
  status                                                       String                     @default("active")
  createdAt                                                    DateTime                   @default(now()) @map("created_at")
  updatedAt                                                    DateTime                   @updatedAt @map("updated_at")
  deletedAt                                                    DateTime?                  @map("deleted_at")
  jobRoleId                                                    String?                    @map("job_role_id")
  documentMetadata                                             Json?                      @map("document_metadata")
  attendanceRecords                                            AttendanceRecord[]
  compensation                                                 Compensation?
  contracts                                                    Contract[]
  department                                                   Department                 @relation(fields: [departmentId], references: [id])
  jobRole                                                      JobRole?                   @relation(fields: [jobRoleId], references: [id])
  location                                                     Location                   @relation(fields: [locationId], references: [id])
  company                                                      Company                    @relation(fields: [tenantId], references: [id])
  hrCases                                                      HRCase[]
  complianceDocuments                                          ComplianceDocument[]
  employeeBenefits                                             EmployeeBenefit[]
  skills                                                       EmployeeSkill[]
  menteePairs                                                  MentorshipPair[]           @relation("hr_mentorship_pairs_mentee_idToemployees")
  mentorPairs                                                  MentorshipPair[]           @relation("hr_mentorship_pairs_mentor_idToemployees")
  performanceGoals                                             PerformanceGoal[]
  successionCandidates                                         SuccessionCandidate[]
  interviews                                                   Interview[]
  itDevices                                                    ITDevice[]
  itProvisioningRequests                                       ITProvisioningRequest[]
  leaveRequests                                                LeaveRequest[]
  payrollLines                                                 PayrollLine[]
  payrollProfile                                               PayrollProfile?
  performanceReviews                                           PerformanceReview[]        @relation("SubjectEmployee")
  assignedReviews                                              PerformanceReview[]        @relation("ReviewerEmployee")
  procurementRequisitions                                      ProcurementRequisition[]
  retailOrders                                                 RetailOrder[]
  retailShifts                                                 RetailShift[]
  scheduleAssignments                                          ScheduleAssignment[]
  managedStores                                                Store[]
  trainingAssignments                                          TrainingAssignment[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@index([locationId])
  @@index([departmentId])
  @@index([status])
  @@index([email])
  @@map("employees")
}

model AttendanceRecord {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  employeeId      String    @map("employee_id")
  locationId      String    @map("location_id")
  date            DateTime
  checkIn         Json?     @map("check_in")
  checkOut        Json?     @map("check_out")
  status          String    @default("present")
  type            String    @default("web")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  shiftId             String?   @map("shift_id")
  workDurationMinutes Int       @default(0) @map("work_duration_minutes")
  employee            Employee  @relation(fields: [employeeId], references: [id])
  location            Location  @relation(fields: [locationId], references: [id])
  shift               Shift?    @relation(fields: [shiftId], references: [id])
  company             Company   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([date])
  @@map("hr_attendance_records")
}

model LeaveRequest {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  employeeId   String     @map("employee_id")
  startDate    DateTime   @map("start_date")
  endDate      DateTime   @map("end_date")
  reason       String?
  status       String     @default("requested")
  approvedBy   String?    @map("approved_by")
  approvedAt   DateTime?  @map("approved_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  approvalId   String?    @map("approval_id")
  departmentId String     @map("department_id")
  type         String
  deleted_at   DateTime?
  department   Department @relation(fields: [departmentId], references: [id])
  employee     Employee   @relation(fields: [employeeId], references: [id])
  company      Company    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}


model PayrollLine {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  payrollRunId String     @map("payroll_run_id")
  employeeId   String     @map("employee_id")
  grossPay     Decimal    @map("gross_pay") @db.Decimal(15, 2)
  netPay       Decimal    @map("net_pay") @db.Decimal(15, 2)
  adjustments  Decimal    @default(0) @map("adjustments") @db.Decimal(15, 2)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  employee     Employee   @relation(fields: [employeeId], references: [id])
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id])
  company      Company    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@map("payroll_lines")
}

model Contract {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  employeeId String?   @map("employee_id")
  title      String
  type       String
  status     String    @default("active")
  startDate  DateTime  @map("start_date")
  endDate    DateTime? @map("end_date")
  url        String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  employee   Employee? @relation(fields: [employeeId], references: [id])
  company    Company   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
  @@map("contracts")
}

model PerformanceReview {
  id         String           @id @default(uuid())
  tenantId   String           @map("tenant_id")
  cycleId    String           @map("cycle_id")
  employeeId String           @map("employee_id")
  reviewerId String           @map("reviewer_id")
  status     String           @default("pending")
  rating     Int?
  comments   String?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  cycle      PerformanceCycle @relation(fields: [cycleId], references: [id])
  employee   Employee         @relation("SubjectEmployee", fields: [employeeId], references: [id])
  reviewer   Employee         @relation("ReviewerEmployee", fields: [reviewerId], references: [id])
  company    Company          @relation("CompanyToPerformanceReview", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([cycleId])
  @@index([employeeId])
  @@map("performance_reviews")
}

model JobRequisition {
  id           String       @id @default(uuid())
  tenantId     String       @map("tenant_id")
  departmentId String?      @map("department_id")
  title        String
  status       String       @default("open")
  openings     Int          @default(1)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  candidates   Candidate[]
  department   Department?  @relation(fields: [departmentId], references: [id])
  company      Company      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("job_requisitions")
}

model Shift {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  name              String
  startTime         String               @map("start_time")
  endTime           String               @map("end_time")
  breakDuration     Int                  @default(0) @map("break_duration")
  flexibleWindow    Int                  @default(0) @map("flexible_window")
  workDays          Int[]                @map("work_days")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  deleted_at        DateTime?
  attendanceRecords AttendanceRecord[]
  assignments       ScheduleAssignment[]
  company           Company              @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("shifts")
}

model ScheduleAssignment {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  employeeId    String   @map("employee_id")
  shiftId       String   @map("shift_id")
  locationId    String   @map("location_id")
  effectiveDate DateTime @map("effective_date")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  employee      Employee @relation(fields: [employeeId], references: [id])
  location      Location @relation(fields: [locationId], references: [id])
  shift         Shift    @relation(fields: [shiftId], references: [id])
  company       Company  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@map("schedule_assignments")
}

model ShiftSwapRequest {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  requesterId String   @map("requester_id")
  targetId    String   @map("target_id")
  shiftId     String   @map("shift_id")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  company     Company  @relation(fields: [tenantId], references: [id])

  @@map("shift_swap_requests")
}

model EmergencyOverride {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  employeeId String   @map("employee_id")
  reason     String
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  company    Company  @relation(fields: [tenantId], references: [id])

  @@map("emergency_overrides")
}

model TrainingProgram {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  name              String
  status            String               @default("active")
  completionRate    Float                @default(0) @map("completion_rate")
  dueDate           DateTime?            @map("due_date")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  skills            ProgramSkill[]
  assignments       TrainingAssignment[]
  company           Company              @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("training_programs")
}

model TrainingAssignment {
  id          String          @id @default(uuid())
  tenantId    String          @map("tenant_id")
  programId   String          @map("program_id")
  employeeId  String          @map("employee_id")
  status      String          @default("in_progress")
  assignedAt  DateTime        @map("assigned_at")
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  employee    Employee        @relation(fields: [employeeId], references: [id])
  program     TrainingProgram @relation(fields: [programId], references: [id])
  company     Company         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([programId])
  @@index([employeeId])
  @@map("training_assignments")
}

model Store {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  locationId      String               @map("location_id")
  name            String
  code            String
  type            String
  status          String               @default("active")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  deletedAt       DateTime?            @map("deleted_at")
  managerId       String?              @map("manager_id")
  email           String?
  inventoryPoolId String?              @map("inventory_pool_id")
  operatingHours  Json?                @map("operating_hours")
  phone           String?
  settings        Json?                @map("settings")
  timezone        String?              @default("Asia/Jakarta")
  country         String?
  currency        String?
  devices         POSDevice[]
  orders          RetailOrder[]
  shifts          RetailShift[]
  inventoryPool   InventoryPool?       @relation(fields: [inventoryPoolId], references: [id])
  location        Location             @relation(fields: [locationId], references: [id])
  manager         Employee?            @relation(fields: [managerId], references: [id])
  company         Company              @relation(fields: [tenantId], references: [id])
  ecommerceStores EcommerceConnector[] @relation("EcommerceBranchLinks")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([locationId])
  @@index([status])
  @@map("stores")
}

model EcommerceConnector {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  domain          String
  apiKey          String         @unique @map("api_key")
  status          String         @default("active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  inventoryPoolId String?        @map("inventory_pool_id")
  managerId       String?        @map("manager_id")
  name            String         @default("")
  platform        String         @default("custom")
  settings        Json?          @map("settings")
  inventoryPool   InventoryPool? @relation(fields: [inventoryPoolId], references: [id])
  company         Company        @relation(fields: [tenantId], references: [id])
  branches        Store[]        @relation("EcommerceBranchLinks")

  @@index([tenantId])
  @@index([apiKey])
  @@index([status])
  @@map("ecommerce_connectors")
}

model ProductCategory {
  id        String            @id @default(uuid())
  tenantId  String            @map("tenant_id")
  name      String
  parentId  String?           @map("parent_id")
  icon      String?
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  products  Product[]
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryHierarchy")
  company   Company           @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id            String                @id @default(uuid())
  tenantId      String                @map("tenant_id")
  categoryId    String                @map("category_id")
  name          String
  sku           String
  barcode       String
  description   String?
  unit          String
  basePrice     Decimal               @map("base_price") @db.Decimal(15, 2)
  taxRate       Decimal               @default(0.11) @map("tax_rate") @db.Decimal(5, 2)
  imageUrl      String?               @map("image_url")
  moduleTags    String[]              @default([]) @map("module_tags")
  status        String                @default("active")
